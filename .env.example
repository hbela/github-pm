# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Generate with: openssl rand -hex 32
AUTH_SECRET=

NEXTAUTH_URL=http://localhost:3000

# GitHub Personal Access Token — used by the GitHub MCP server (Claude Code)
# Create at: https://github.com/settings/tokens → Fine-grained token
# Required scopes: repo (read), issues (read/write)
GITHUB_PAT=

# Claude API key — required for Phase 3+ AI features
# Create at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# GitHub Webhook secret — Phase 4 webhook integration
# Set the same value in your GitHub repo webhook settings
GITHUB_WEBHOOK_SECRET=
